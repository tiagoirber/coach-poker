# =============================================================
# VARIÁVEIS DE AMBIENTE — copie este arquivo para .env
# e preencha com seus valores reais
# =============================================================

# Porta do servidor Express (padrão: 3000)
PORT=3000

# URL do frontend (para o CORS liberar acesso)
# Em produção: sua URL do Firebase Hosting
FRONTEND_URL=http://localhost:5500

# Chave da API Claude (fica no servidor, nunca no frontend)
CLAUDE_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# Caminho para o arquivo de credenciais do Firebase Admin SDK
# Baixe em: Firebase Console → Configurações → Contas de serviço
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
